{
    "extends": "../tsconfig.json",
    "compilerOptions": {
      "rootDir": "..",  // Change this to allow access to parent directory
      "outDir": "../dist/examples",
      "noEmit": true,
      "paths": {
        "accountstate": ["../src/index.ts"],
        "accountstate/binance": ["../src/adapters/binance/index.ts"],
        "accountstate/bybit": ["../src/adapters/bybit/index.ts"],
        "accountstate/conformance": ["../src/conformance.ts"],
        "accountstate/core": ["../src/core/index.ts"],
        "*": ["../src/*"]
      }
    },
    "include": ["./**/*"],
    "exclude": [
      "node_modules",
      "bybit-futures.ts" // Legacy example excluded from active example typecheck
    ]
  }
